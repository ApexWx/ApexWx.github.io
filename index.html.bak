  "06-02": { high: [92, 2023], low: [29, 2020], rain: [1.30, 1994] },
  "06-03": { high: [90, 1963], low: [31, 2020], rain: [1.18, 2013] },
  "06-04": { high: [88, 1990], low: [29, 1953], rain: [1.14, 2001] },
  "06-05": { high: [90, 1893], low: [29, 2000], rain: [0.74, 1952] },
  "06-06": { high: [86, 1976], low: [29, 1894], rain: [1.08, 1952] },
  "06-07": { high: [91, 1976], low: [29, 1948], rain: [1.28, 1983] },
  "06-08": { high: [91, 2021], low: [30, 1951], rain: [2.00, 1930] },
  "06-09": { high: [93, 1893], low: [31, 1957], rain: [3.92, 2011] },
  "06-10": { high: [88, 1984], low: [29, 1958], rain: [1.78, 1950] },
  "06-11": { high: [91, 1942], low: [31, 2018], rain: [1.60, 2006] },
  "06-12": { high: [91, 1942], low: [30, 1950], rain: [1.55, 1976] },
  "06-13": { high: [96, 1893], low: [34, 1976], rain: [1.34, 1996] },
  "06-14": { high: [95, 1956], low: [32, 2002], rain: [1.18, 1928] },
  "06-15": { high: [94, 1956], low: [31, 2018], rain: [1.10, 1947] }
};

// New Astronomy Worker Fetch Function
  async function loadFortKentAstroData() {
    // Replace this placeholder string with your real Cloudflare Worker URL
    const workerEndpoint = 'https://moon-api.maineapexwx.workers.dev/';

    try {
      const response = await fetch(workerEndpoint);
      if (!response.ok) throw new Error("Astro API returned an error status.");
      
      const data = await response.json();

      // Map the JSON payloads securely to your HTML element IDs
      document.getElementById('astro-date').textContent = data.date_label;
      document.getElementById('astro-sunrise').textContent = data.sunrise;
      document.getElementById('astro-sunset').textContent = data.sunset;
      document.getElementById('astro-day-length').textContent = data.day_length;
      document.getElementById('astro-moon-phase').textContent = data.moon_phase_display;
      document.getElementById('astro-moonset').textContent = data.moonset_display;
      document.getElementById('astro-moonrise').textContent = data.moonrise_display;

    } catch (error) {
      console.error("Failed to inject Naval astronomical predictions:", error);
      document.getElementById('astro-date').textContent = "Data Temporarily Offline";
    }
  }

  // --- EXECUTION SECTION ---
  
  // 1. Fire your existing climate sequence immediately & queue its 30-min loop
  loadClimateData();
  setInterval(loadClimateData, 1800000); 

  // 2. Fire your new astronomy sequence immediately (No loop required)
  loadFortKentAstroData();

</script>
