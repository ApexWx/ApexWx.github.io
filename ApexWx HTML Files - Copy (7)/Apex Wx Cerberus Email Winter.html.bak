                          <div><u><strong>Monday, April 13</strong></u>
                            <div> </div>
                            <div style="width: 810px;"><strong>Normal High: </strong>44°
                              |<strong> Record High</strong>: 81° (1945)<br>
                              <strong> Normal Low:&nbsp; </strong>24° | <strong>Record
                                Low:&nbsp;&nbsp; </strong>4<strong>°</strong>
                              (1985)<br>
                              <strong>Normal Daily Precipitation: </strong>0.10"<strong>
                              </strong>|<strong> Record Precipitation</strong>:
                              1.83" (1940)</div>
                            <div style="width: 810px;"><strong>Normal Daily
                                Snowfall:</strong> 0.2" | <strong>Record
                                Snowfall</strong>: 8.0" (1943)</div>
                            <div style="width: 810px;"><em style="font-size: 12px;">Source:
                                </em><em style="font-size: 12px;"><em style="font-size: 12px;"><a
                                    href="https://scacis.rcc-acis.org/">NOAA
                                    SC-ACIS</a> </em>NWS Caribou climate data<br>
                              </em></div>
                            <div style="width: 810px;"><br>
                            </div>
                            <u><strong>Precipitation 2026</strong></u><br>
                            <strong></strong>
                            <div style="width: 810px;"><strong>Rain</strong><strong>:</strong>
                              8.99" | <u>normal</u>: 9.13 (<span style="color: red;">-0.14"</span>)<span
                                style="color: #009900;"></span><br>
                              <strong>Snow 25-26</strong><strong>: </strong>78.3"
                              | <u>normal</u>: 96.9" (<span style="color: red;">-18.6"</span>)</div>
                          </div>
                          <span style="color: red;"></span>
                          <div>
