    statusMessage.classList.add('bg-red-800/20', 'border-red-700/50',
    'text-red-300'); statusMessage.innerHTML = `
    <p class="text-lg font-semibold">Error: ${message}</p>
    <p class="mt-1 text-sm">Please try another date.</p>
    `; citationContainer.classList.add('hidden'); // Clear the moon canvas on
    error ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE); } function hideStatus()
    { statusMessage.classList.add('hidden');
    dataContainer.classList.remove('hidden'); } function
    formatPhaseName(apiPhase) { // Converts API_KEY_CASE to Title Case return
    apiPhase .replace(/_/g, ' ') .toLowerCase() .split(' ') .map(word =&gt;
    word.charAt(0).toUpperCase() + word.slice(1)) .join(' '); } function
    updateDisplay(data) { // Moonrise and Moonset moonRiseElement.textContent =
    data.moonrise || 'N/A'; moonSetElement.textContent = data.moonset || 'N/A';
    // Illumination const illumination =
    parseFloat(data.moon_illumination_percentage);
    illuminationElement.textContent = `${illumination.toFixed(1)}%`; // Moon
    Phase Name const phaseName = formatPhaseName(data.moon_phase);
    moonPhaseElement.textContent = phaseName; // Draw the graphic
    drawMoonPhase(illumination, data.moon_phase); // Citation
    citationText.textContent = `Data for ${data.date} using an external
    astronomy API.`; citationContainer.classList.remove('hidden'); hideStatus();
    } // --- Canvas Drawing Logic --- function drawMoonPhase(illumination,
    phase) { // Clear the canvas ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
    // Draw the night-sky border ctx.beginPath(); ctx.arc(CENTER, CENTER, RADIUS
    + 2, 0, Math.PI * 2); ctx.strokeStyle = 'rgba(241, 196, 15, 0.4)'; //
    Star-yellow border ctx.lineWidth = 2; ctx.stroke(); // 1. Draw the moon's
    outline (the dark side) ctx.beginPath(); ctx.arc(CENTER, CENTER, RADIUS, 0,
    Math.PI * 2); ctx.fillStyle = '#2c3e50'; // Dark side color ctx.fill(); //
    2. Draw the fully illuminated circle on the canvas if (illumination &gt; 0
    &amp;&amp; illumination &lt; 100) { // Draw the fully lit portion (the full
    circle, before masking) ctx.beginPath(); ctx.arc(CENTER, CENTER, RADIUS, 0,
    Math.PI * 2); ctx.fillStyle = 'white'; // Illuminated color ctx.fill(); //
    The shadow logic relies on two arcs: a semi-circle and an ellipse const
    isWaxing = phase.includes('WAXING') || phase.includes('FIRST_QUARTER');
    const isWaning = phase.includes('WANING') ||
    phase.includes('THIRD_QUARTER'); // Calculate the position and shape of the
    elliptical shadow boundary // Illumination (I) is 0 to 100. Normalize to 0
    to 1. const I = illumination / 100; let x_offset = 0; let w = 0; // Width of
    the elliptical shadow boundary let startAngle = 0; // Angle for the
    semi-circle (0 is right side) let endAngle = 0; if (isWaxing) { // Waxing:
    Shadow is on the left side, moving right if (I &lt;= 0.5) { // Crescent
    (shadow is large) // Shadow covers more than half x_offset = CENTER +
    (RADIUS * 2 * I) - RADIUS; w = RADIUS * 2 * (0.5 - I); // Width of the
    crescent shadow startAngle = Math.PI * 0.5; // Top to Bottom endAngle =
    Math.PI * 1.5; } else { // Gibbous (shadow is small) // Shadow covers less
    than half x_offset = CENTER + (RADIUS * 2 * I) - RADIUS; w = RADIUS * 2 * (1
    - I); startAngle = Math.PI * 1.5; // Bottom to Top endAngle = Math.PI * 0.5;
    } } else if (isWaning) { // Waning: Shadow is on the right side, moving left
    if (I &lt;= 0.5) { // Crescent (shadow is large) // Shadow covers more than
    half x_offset = CENTER - (RADIUS * 2 * I) + RADIUS; w = RADIUS * 2 * (0.5 -
    I); startAngle = Math.PI * 1.5; // Bottom to Top endAngle = Math.PI * 0.5; }
    else { // Gibbous (shadow is small) // Shadow covers less than half x_offset
    = CENTER - (RADIUS * 2 * I) + RADIUS; w = RADIUS * 2 * (1 - I); startAngle =
    Math.PI * 0.5; // Top to Bottom endAngle = Math.PI * 1.5; } } // Mask the
    illuminated circle with the shadow color ctx.fillStyle = '#2c3e50';
    ctx.beginPath(); // 1. Draw the semi-circular arc for the simple half-shadow
    (always needed) ctx.arc(CENTER, CENTER, RADIUS, startAngle, endAngle,
    isWaxing); // 2. Draw the elliptical arc for the curved shadow boundary if
    (phase !== 'FIRST_QUARTER' &amp;&amp; phase !== 'THIRD_QUARTER') { // Use an
    ellipse to connect the semi-circle back to the start point // The scaleX
    determines the curvature of the shadow const scaleX = w / RADIUS;
    ctx.save(); ctx.translate(CENTER, CENTER); // Move to center for
    rotation/scaling ctx.scale(scaleX, 1); ctx.arc(0, 0, RADIUS, Math.PI * 0.5,
    Math.PI * 1.5, isWaxing); ctx.restore(); } ctx.fill(); } else if
    (illumination === 100) { // Full Moon ctx.beginPath(); ctx.arc(CENTER,
    CENTER, RADIUS, 0, Math.PI * 2); ctx.fillStyle = 'white'; ctx.fill(); } //
    Note: No drawing needed for New Moon (illumination ≈ 0), as the dark outline
    is already drawn. } // --- API Logic --- async function
    fetchAstronomyData(date, attempt = 0) { const MAX_RETRIES = 3; const API_URL
    =
    `https://api.ipgeolocation.io/astronomy?apiKey=${API_KEY}&amp;lat=${FORT_KENT_LAT}&amp;long=${FORT_KENT_LONG}&amp;date=${date}`;

    showLoading(); try { const response = await fetch(API_URL, { method: 'GET',
    headers: { 'Content-Type': 'application/json' } }); if (!response.ok) {
    const errorBody = await response.json(); throw new Error(`API returned
    status ${response.status}: ${errorBody.message || 'Unknown error'}`); }
    const data = await response.json(); // Check for specific application-level
    errors (e.g., date out of range) if (data.status === 400 ||
    !data.moon_phase) { throw new Error(data.message || "No data available for
    this date/location."); } updateDisplay(data); } catch (error) {
    console.error("API Fetch Error:", error.message); if (attempt &lt;
    MAX_RETRIES) { const delay = Math.pow(2, attempt) * 1000; // Exponential
    backoff: 1s, 2s, 4s // console.log(`Retrying in ${delay}ms...`); await new
    Promise(resolve =&gt; setTimeout(resolve, delay)); return
    fetchAstronomyData(date, attempt + 1); } else { showError("Failed to fetch
    astronomy data after multiple retries. The external API may be unavailable
    or rate-limited."); } } } // Initial load and event listener setup
    dateInput.addEventListener('change', (event) =&gt; {
    fetchAstronomyData(event.target.value); }); // Fetch data for today on
    initial load fetchAstronomyData(today); });
