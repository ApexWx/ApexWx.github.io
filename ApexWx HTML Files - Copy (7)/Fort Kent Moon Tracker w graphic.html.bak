    statusMessage.classList.add('bg-blue-800/20', 'border-blue-700/50',
    'text-blue-300'); statusMessage.innerHTML = '
    <div class="flex justify-center items-center">
      <div class="spinner"></div>
      <span class="ml-4 text-lg font-medium">Fetching data...</span></div>
    '; citationContainer.classList.add('hidden'); } function showError(message)
