<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <title>Forecast Wall</title>
    <!-- Makes the page responsive on phones/tablets -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body>
    <style>
/* ---------- PAGE STYLE ---------- */
body{
    margin:0;
    padding:10px;
    font-family:Arial, sans-serif;
    background:url('https://github.com/ApexWx/ApexWx.github.io/blob/master/seamless-background-simply-sky.jpg?raw=true') repeat;
    color:black;
    text-shadow: 0 0 3px rgba(255,255,255,0.7);
}

/* Center page width only (no background panel) */
.container{
    max-width:1240px;
    margin:auto;
}

/* Tables scale and have subtle contrast */
table{
    width:100%;
    border-collapse:collapse;
    background:rgba(255,255,255,0.55);
    border-radius:6px;
    overflow:hidden;
    margin-bottom:10px;
}

/* All table cells bold + spacing */
td{
    font-weight:bold;
    padding:10px;
    vertical-align:top;
}

/* Images responsive */
img{
    width:100%;
    height:auto;
    max-width:600px;
    border-radius:6px;
}

/* Navigation styling */
.nav td{
    text-align:center;
    background:rgba(255,255,255,0.75);
}

/* Section title */
.sectiontitle{
    text-align:center;
    font-size:18px;
    background:rgba(255,255,255,0.75);
}

/* Links */
a{
    color:black;
    text-decoration:none;
}

/* Hover effect (nice polish) */
a:hover{
    text-decoration:underline;
}

/* Divider */
hr{
    border:1px solid rgba(0,0,0,0.3);
}

/* ---------- MOBILE RESPONSIVE ---------- */
@media screen and (max-width:900px){

    td{
        display:block;
        width:100%;
        text-align:center;
    }

    img{
        max-width:100%;
    }

}
    /* ---------- IMAGE IMPROVEMENTS ---------- */

/* Smooth fade-in when images load */
img{
    width:100%;
    height:auto;
    max-width:600px;
    border-radius:6px;
    cursor:zoom-in;
    opacity:0;
    transition:opacity 0.4s ease;
}

/* When loaded */
img.loaded{
    opacity:1;
}

/* ---------- LIGHTBOX (ZOOM) ---------- */

#lightbox{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.85);
    display:none;
    justify-content:center;
    align-items:center;
    z-index:9999;
    cursor:zoom-out;
}

#lightbox img{
    max-width:95%;
    max-height:95%;
    border-radius:8px;
}
    
    </style>
