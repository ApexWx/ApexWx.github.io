<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ApexWx - Fort Kent Weather Layout</title>
    <style>
        /* 1. Reset & Base Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            color: #1e293b;
            
            /* Integrated Custom Seamless Sky Background */
            background-image: url('https://github.com/ApexWx/ApexWx.github.io/blob/master/seamless-background-simply-sky.jpg?raw=true');
            background-repeat: repeat;
            background-position: center top;
            background-attachment: fixed;
            
            /* Keeps the footer pushed to the bottom if content is short */
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* 2. Layout Containers */
        header, footer {
            background-color: #1a1a1a;
            color: #ffffff;
            padding: 1.5rem 1rem;
            text-align: center;
        }

        /* The central single column wrapper */
        .container {
            width: 100%;
            max-width: 800px; /* Restricts width on large screens for ideal readability */
            margin: 0 auto;   /* Centers the column horizontally */
            padding: 0 1.5rem; /* Prevents text from hitting screen edges on mobile */
        }

        main {
            flex: 1; /* Grows to fill available vertical space */
            padding: 3rem 0;
        }

        /* Text readability backing panels for content over the custom background image */
        .content-panel {
            background-color: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            margin-bottom: 2rem;
        }

        /* 3. Typography & Elements */
        header h1 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }
        
        header h1 span {
            color: #00bcd4;
        }

        nav a {
            color: #00bcd4;
            text-decoration: none;
            margin: 0 0.75rem;
            font-size: 0.95rem;
            font-weight: 600;
        }

        nav a:hover {
            text-decoration: underline;
        }

        article h2 {
            font-size: 1.8rem;
            margin-bottom: 0.2rem;
            color: #1a1a1a;
        }

        .panel-subtitle {
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 1rem;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 0.5rem;
            font-weight: 500;
        }

        article h3 {
            font-size: 1.3rem;
            margin: 1.5rem 0 0.5rem
              </style>
  </head>
  <body><br>
  </body>
</html>
